# Backend environment variables
# Copy this to .env and fill in values

# MongoDB (optional — omit to run in flat-file mode only)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ai_interview_sim

# LLM scoring — pre-warm Qwen2.5-7B at startup (adds ~90s)
LLM_EAGER_LOAD=false

# HuggingFace token (optional — for higher rate limits on model downloads)
# HF_TOKEN=hf_...

# Cleanup security (optional)
CLEANUP_SECRET=
ADMIN_SECRET=
